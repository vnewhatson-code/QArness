#!/bin/bash
# QArness CLI utility

QARNESS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION=$(cat "$QARNESS_DIR/.version" 2>/dev/null || echo "unknown")

# Source libraries
source "$QARNESS_DIR/lib/common.sh"
source "$QARNESS_DIR/lib/config-manager.sh"
source "$QARNESS_DIR/lib/proxy-handler.sh"

# Initialize
init_logging

usage() {
    cat << EOF
QArness v$VERSION - AI-инструмент автоматизации QA работы

Использование:
  qarness <команда> [опции]

Команды:
  install             Установка/переустановка QArness
  update              Проверка и установка обновлений
  status              Статус установки и интеграций
  config              Управление конфигурацией
  integrate [ai]      Интеграция с AI-ассистентом
  remove              Удаление QArness
  version             Версия QArness
  doctor              Диагностика проблем
  help                Показать эту справку

Примеры:
  qarness update
  qarness integrate opencode
  qarness config proxy set http://proxy.company.com:8080
  qarness doctor

Документация: https://github.com/vnewhatson-code/QArness
EOF
}

# Install command
cmd_install() {
    print_header "Установка QArness"
    
    if [ -f "$QARNESS_DIR/install.sh" ]; then
        bash "$QARNESS_DIR/install.sh"
    else
        error "Скрипт установки не найден"
    fi
}

# Update command
cmd_update() {
    print_header "Проверка обновлений"
    
    cd "$QARNESS_DIR" || error "Не удается найти директорию QArness"
    
    # Setup proxy if configured
    detect_proxy
    if [ "$PROXY_DETECTED" = "yes" ]; then
        setup_proxy_for_git
    fi
    
    # Fetch latest changes
    log "Проверка обновлений..."
    git fetch origin
    
    LOCAL=$(git rev-parse @ 2>/dev/null)
    REMOTE=$(git rev-parse @{u} 2>/dev/null)
    
    if [ "$LOCAL" = "$REMOTE" ]; then
        print_success "QArness уже обновлен до последней версии"
        return 0
    fi
    
    # Get latest version tag
    LATEST_VERSION=$(git describe --tags --abbrev=0 2>/dev/null || echo "main")
    log "Доступна новая версия: $LATEST_VERSION"
    
    # Show changes
    echo
    echo "Изменения:"
    git log --oneline --decorate --graph HEAD..@{u} | head -10
    echo
    
    if confirm "Обновить?"; then
        git pull origin main
        
        if [ $? -eq 0 ]; then
            print_success "Обновление завершено"
            
            # Update integrations
            log "Обновление интеграций..."
            bash "$QARNESS_DIR/scripts/integrate-ai.sh" --update-all
            
            # Update version in config
            NEW_VERSION=$(cat "$QARNESS_DIR/.version" 2>/dev/null || echo "unknown")
            set_config "version" "$NEW_VERSION"
            
            # Set last update check
            set_last_update_check
            
            print_success "QArness обновлен до версии $NEW_VERSION"
        else
            print_error "Ошибка обновления"
            return 1
        fi
    else
        log "Обновление отменено"
    fi
}

# Status command
cmd_status() {
    print_header "Статус QArness"
    
    echo "Версия: $VERSION"
    echo "Установлен в: $QARNESS_DIR"
    echo
    
    # Check integrations
    echo "Интегрированные AI-ассистенты:"
    
    if is_integration_enabled "opencode"; then
        local path=$(get_config "integrations.opencode.configPath")
        echo "  ✓ OpenCode ($path)"
    else
        echo "  ✗ OpenCode"
    fi
    
    if is_integration_enabled "claude"; then
        local path=$(get_config "integrations.claude.configPath")
        echo "  ✓ Claude Desktop ($path)"
    else
        echo "  ✗ Claude Desktop"
    fi
    
    echo
    
    # Check dependencies
    echo "Зависимости:"
    
    if check_dependency "git"; then
        echo "  ✓ Git $(get_version git)"
    else
        echo "  ✗ Git не установлен"
    fi
    
    if check_dependency "node"; then
        echo "  ✓ Node.js $(get_version node)"
    else
        echo "  ✗ Node.js не установлен"
    fi
    
    if check_dependency "npm"; then
        echo "  ✓ npm $(get_version npm)"
    else
        echo "  ✗ npm не установлен"
    fi
    
    echo
    
    # Check proxy
    local proxy=$(get_proxy_config)
    if [ -n "$proxy" ] && [ "$proxy" != "null" ]; then
        echo "Прокси: $proxy"
    else
        echo "Прокси: не настроен"
    fi
    
    echo
}

# Config command
cmd_config() {
    case "$1" in
        proxy)
            case "$2" in
                set)
                    if [ -z "$3" ]; then
                        error "Использование: qarness config proxy set <url>"
                    fi
                    set_proxy_config "$3"
                    setup_proxy_for_git
                    setup_proxy_for_npm
                    print_success "Прокси установлен: $3"
                    ;;
                test)
                    test_proxy
                    ;;
                clear)
                    clear_proxy_config
                    clear_proxy_for_git
                    clear_proxy_for_npm
                    print_success "Прокси удален"
                    ;;
                *)
                    echo "Использование: qarness config proxy <set|test|clear> [url]"
                    echo
                    echo "Примеры:"
                    echo "  qarness config proxy set http://proxy.company.com:8080"
                    echo "  qarness config proxy test"
                    echo "  qarness config proxy clear"
                    ;;
            esac
            ;;
        show)
            show_config
            ;;
        reset)
            if confirm "Сбросить конфигурацию к значениям по умолчанию?"; then
                reset_config
                print_success "Конфигурация сброшена"
            fi
            ;;
        *)
            echo "Доступные настройки:"
            echo "  proxy    - Настройка прокси"
            echo "  show     - Показать текущую конфигурацию"
            echo "  reset    - Сбросить конфигурацию"
            echo
            echo "Использование: qarness config <setting> <action> [value]"
            ;;
    esac
}

# Integrate command
cmd_integrate() {
    local ai="${1:-}"
    
    if [ -z "$ai" ]; then
        # Show available assistants
        echo "Доступные AI-ассистенты для интеграции:"
        echo "  opencode    - OpenCode"
        echo "  claude      - Claude Desktop"
        echo
        echo "Использование: qarness integrate <ai-name>"
        return 1
    fi
    
    # Detect AI assistant
    source "$QARNESS_DIR/scripts/detect-ai.sh"
    detect_ai_assistants > /dev/null
    
    local config_path=$(get_ai_config_path "$ai")
    
    if [ -z "$config_path" ]; then
        warn "$ai не обнаружен"
        echo
        echo "Возможные причины:"
        echo "  - $ai не установлен"
        echo "  - Конфигурация находится в нестандартном месте"
        echo
        read -p "Указать путь к конфигурации вручную? [y/N] " -n 1 -r
        echo
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            read -p "Путь к конфигурации $ai: " config_path
            config_path=$(expand_path "$config_path")
        else
            return 1
        fi
    fi
    
    # Integrate
    bash "$QARNESS_DIR/scripts/integrate-ai.sh" "$ai" "$config_path"
}

# Remove command
cmd_remove() {
    print_header "Удаление QArness"
    
    warn "Это удалит QArness и все его файлы"
    
    if ! confirm "Продолжить?"; then
        log "Удаление отменено"
        return 0
    fi
    
    # Remove integrations
    log "Удаление интеграций..."
    local assistants=$(get_integrated_assistants)
    
    for assistant in $assistants; do
        bash "$QARNESS_DIR/scripts/integrate-ai.sh" --remove "$assistant"
    done
    
    # Remove CLI symlink
    if [ -L "/usr/local/bin/qarness" ]; then
        if [ -w "/usr/local/bin" ]; then
            rm "/usr/local/bin/qarness"
            log "CLI команда удалена"
        else
            warn "Нет прав для удаления /usr/local/bin/qarness"
            info "Удалите вручную: sudo rm /usr/local/bin/qarness"
        fi
    fi
    
    # Remove QArness directory
    log "Удаление файлов QArness..."
    
    # We can't remove ourselves while running, so we create a cleanup script
    cat > /tmp/qarness-cleanup.sh << 'EOF'
#!/bin/bash
sleep 1
rm -rf "${HOME}/.qarness"
echo "QArness удален"
rm -- "$0"
EOF
    
    chmod +x /tmp/qarness-cleanup.sh
    /tmp/qarness-cleanup.sh &
    
    print_success "QArness будет удален через несколько секунд"
}

# Doctor command
cmd_doctor() {
    print_header "Диагностика QArness"
    
    local issues=0
    
    # Check 1: Files integrity
    log "Проверка целостности файлов..."
    local required_files=("agents" "skills" "scripts" "config" "lib" ".version")
    
    for file in "${required_files[@]}"; do
        if [ ! -e "$QARNESS_DIR/$file" ]; then
            warn "Отсутствует: $file"
            issues=$((issues + 1))
        fi
    done
    
    # Check 2: Dependencies
    log "Проверка зависимостей..."
    
    if ! check_dependency "git"; then
        warn "Git не установлен"
        issues=$((issues + 1))
    fi
    
    if ! check_dependency "node"; then
        warn "Node.js не установлен"
        issues=$((issues + 1))
    fi
    
    if ! check_dependency "npm"; then
        warn "npm не установлен"
        issues=$((issues + 1))
    fi
    
    if ! check_dependency "jq" && ! check_dependency "python3"; then
        warn "jq или python3 не установлены (нужен хотя бы один)"
        issues=$((issues + 1))
    fi
    
    # Check 3: Integrations
    log "Проверка интеграций..."
    
    if is_integration_enabled "opencode"; then
        local path=$(get_config "integrations.opencode.configPath")
        if [ -d "$path" ]; then
            if file_exists "$path/opencode.json" || file_exists "$path/opencode.jsonc"; then
                log "OpenCode интеграция: OK"
            else
                warn "OpenCode конфигурация не найдена"
                issues=$((issues + 1))
            fi
        else
            warn "OpenCode путь не существует: $path"
            issues=$((issues + 1))
        fi
    fi
    
    # Check 4: Proxy (if configured)
    local proxy=$(get_proxy_config)
    if [ -n "$proxy" ] && [ "$proxy" != "null" ]; then
        log "Проверка прокси..."
        if ! test_proxy "$proxy" > /dev/null 2>&1; then
            warn "Прокси недоступен: $proxy"
            issues=$((issues + 1))
        fi
    fi
    
    # Check 5: Git repository
    log "Проверка Git репозитория..."
    cd "$QARNESS_DIR"
    
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        warn "QArness не является Git репозиторием"
        issues=$((issues + 1))
    fi
    
    # Summary
    echo
    if [ $issues -eq 0 ]; then
        print_success "✓ Проблем не обнаружено"
    else
        warn "Обнаружено проблем: $issues"
        echo
        echo "Рекомендации:"
        echo "  1. Переустановите QArness: qarness install"
        echo "  2. Проверьте зависимости: bash $QARNESS_DIR/scripts/install-deps.sh --check"
        echo "  3. Проверьте логи: cat $LOG_FILE"
    fi
}

# Check for updates automatically
check_updates_auto() {
    if should_check_update; then
        log "Проверка обновлений..."
        
        cd "$QARNESS_DIR"
        detect_proxy
        if [ "$PROXY_DETECTED" = "yes" ]; then
            setup_proxy_for_git
        fi
        
        git fetch origin --quiet 2>/dev/null || return
        
        LOCAL=$(git rev-parse @ 2>/dev/null)
        REMOTE=$(git rev-parse @{u} 2>/dev/null)
        
        if [ "$LOCAL" != "$REMOTE" ]; then
            info "Доступно обновление QArness. Выполните: qarness update"
        fi
        
        set_last_update_check
    fi
}

# Main command dispatch
case "$1" in
    install)
        cmd_install
        ;;
    update)
        cmd_update
        ;;
    status)
        check_updates_auto
        cmd_status
        ;;
    config)
        shift
        cmd_config "$@"
        ;;
    integrate)
        cmd_integrate "$2"
        ;;
    remove)
        cmd_remove
        ;;
    version)
        echo "QArness v$VERSION"
        ;;
    doctor)
        cmd_doctor
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        usage
        ;;
    *)
        echo "Неизвестная команда: $1"
        echo
        usage
        exit 1
        ;;
esac
